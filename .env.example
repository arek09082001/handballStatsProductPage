# Public base URL of the site (used for DOI redirect fallback)
NEXT_PUBLIC_BASE_URL=https://www.handballwebseite.de

# --- Brevo (newsletter + contact form) ---
# API key from Brevo > SMTP & API > API Keys
BREVO_API_KEY=

# Newsletter (double opt-in) — ALL THREE are required for the
# confirmation email to be sent. Without BREVO_DOI_TEMPLATE_ID the
# newsletter endpoint returns 503 instead of subscribing without consent.

# ID of the Brevo contact list new subscribers are added to (default: 4)
BREVO_NEWSLETTER_LIST_ID=4

# ID of the Brevo double opt-in template.
# Create it in Brevo > Contacts > Forms > "Double opt-in" template,
# then copy its numeric template ID here. This template MUST contain the
# {{ doubleOptin }} confirmation link, and its sender address must be a
# verified Brevo sender/domain or the email will not be delivered.
BREVO_DOI_TEMPLATE_ID=

# Where users land after clicking the confirmation link.
# Optional — defaults to `${NEXT_PUBLIC_BASE_URL}/?newsletter=confirmed`.
BREVO_DOI_REDIRECT_URL=
