# Public base URL of the site (used to build the newsletter confirmation link)
NEXT_PUBLIC_BASE_URL=https://www.handballwebseite.de

# --- Brevo (newsletter + contact form) ---
# API key from Brevo > SMTP & API > API Keys
BREVO_API_KEY=

# Newsletter (double opt-in via our own confirmation page)
# Flow: signup -> we send a confirmation email via the Brevo transactional
# API -> user clicks the link -> /newsletter/confirm adds them to the list.

# ID of the Brevo contact list confirmed subscribers are added to (default: 4)
BREVO_NEWSLETTER_LIST_ID=4

# Secret used to sign the confirmation link token (HMAC).
# Optional — falls back to BREVO_API_KEY if unset. Set a dedicated random
# value in production if you rotate the Brevo key independently.
NEWSLETTER_CONFIRM_SECRET=
